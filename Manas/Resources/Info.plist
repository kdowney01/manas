<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>NSHealthShareUsageDescription</key>
	<string>Manas reads your heart rate and HRV to monitor your wellbeing and detect early signs of stress.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Manas writes mindfulness session data to help track your mental wellness over time.</string>
	<key>NSCameraUsageDescription</key>
	<string>Manas uses the front camera for rPPG heart rate measurement and optional facial emotion analysis. No video is recorded or transmitted.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Manas optionally analyzes speech patterns for stress signals. Audio is processed on-device and never stored or transmitted.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>Manas sends gentle wellbeing nudges and critical crisis alerts when your signals shift significantly.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
		<string>fetch</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.manas.app.biometric-refresh</string>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>Fonts/Montserrat-Regular.ttf</string>
		<string>Fonts/Montserrat-Medium.ttf</string>
		<string>Fonts/Montserrat-SemiBold.ttf</string>
		<string>Fonts/Montserrat-Bold.ttf</string>
		<string>Fonts/Montserrat-ExtraBold.ttf</string>
	</array>
</dict>
</plist>
